{
  "name": "claude-code-gdscript",
  "owner": {
    "name": "Tommi Waananen"
  },
  "metadata": {
    "description": "GDScript language support for Claude Code",
    "version": "1.3.0"
  },
  "plugins": [
    {
      "name": "gdscript",
      "source": "./",
      "description": "GDScript language support for Claude Code via Godot's built-in LSP",
      "version": "0.3.0",
      "author": {
        "name": "Tommi Waananen"
      },
      "category": "development",
      "strict": false,
      "lspServers": {
        "gdscript": {
          "command": "node",
          "args": ["${CLAUDE_PLUGIN_ROOT}/bridge/gdscript-lsp-bridge.mjs"],
          "startupTimeout": 20000,
          "extensionToLanguage": {
            ".gd": "gdscript"
          }
        }
      }
    }
  ]
}
