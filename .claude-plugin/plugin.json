{
  "name": "gdscript",
  "description": "GDScript language support for Claude Code via Godot's built-in LSP",
  "version": "0.1.0",
  "category": "development",
  "lspServers": {
    "gdscript": {
      "command": "node",
      "args": ["bridge/gdscript-lsp-bridge.mjs"],
      "extensionToLanguage": {
        ".gd": "gdscript"
      }
    }
  }
}
