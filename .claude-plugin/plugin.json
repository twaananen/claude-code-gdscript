{
  "name": "gdscript",
  "description": "GDScript language support for Claude Code via Godot's built-in LSP",
  "version": "0.1.0",
  "author": {
    "name": "Tommi Waananen"
  },
  "homepage": "https://github.com/twaananen/claude-code-gdscript",
  "repository": "https://github.com/twaananen/claude-code-gdscript",
  "license": "MIT",
  "lspServers": {
    "gdscript": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bridge/gdscript-lsp-bridge.mjs"],
      "startupTimeout": 20000,
      "restartOnCrash": true,
      "maxRestarts": 5,
      "extensionToLanguage": {
        ".gd": "gdscript"
      }
    }
  }
}
